# Production Environment Variables
# Copy this file to .env.production and fill in your values

# Database Connection (Get from Hostinger cPanel → Databases)
DATABASE_URL="mysql://username:password@host:3306/database_name"

# Session Secret (Generate a random string)
SESSION_SECRET="change-this-to-a-random-secret-key-min-32-chars"

# Application Settings
NODE_ENV=production
PORT=5000

# Optional: Client chain configuration
VITE_GEMINI_API_KEY="your-gemini-api-key"
GEMINI_API_KEY="your-gemini-api-key"
VITE_STACKS_NETWORK="testnet"
VITE_CONTRACT_ADDRESS="STTCT2FCG2AE0T2Q70KBA1GDM4VN14FRW5A1NBR0"
VITE_ESCROW_CONTRACT_NAME="escrow-multi-token-v7"
VITE_VERIFY_SOULBOUND_CONTRACT_NAME="verify-soulbound"
VITE_REPUTATION_CONTRACT_NAME="rep-sft"
VITE_SBTC_CONTRACT_ADDRESS="ST1F7QA2MDF17S807EPA36TSS8AMEFY4KA9TVGWXT"
VITE_SBTC_CONTRACT_NAME="sbtc-token"
VITE_USDCX_CONTRACT_ADDRESS="SP0000000000000000000000000000000000000000"

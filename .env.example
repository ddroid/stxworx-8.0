# Example Environment Variables
# Copy this file to .env and replace every placeholder before running in production

# Database Connection
DATABASE_URL="mysql://root:root@127.0.0.1:3306/stx_freelance"
GEMINI_API_KEY="replace-with-your-gemini-api-key"

# Authentication Secrets
JWT_SECRET="replace-with-a-random-user-jwt-secret-min-32-chars"
JWT_ADMIN_SECRET="replace-with-a-random-admin-jwt-secret-min-32-chars"

# Application Settings
NODE_ENV=production
PORT=5000

# Optional: Override the Hiro API base URL used by transaction verification
# STACKS_API_URL="https://api.mainnet.hiro.so"
VITE_STACKS_NETWORK="mainnet"
VITE_CONTRACT_ADDRESS="SP37JRPTQ0KFMB3HAFVCCAWDQWHKRJCGBW1W19TJH"
VITE_ESCROW_CONTRACT_NAME="escrow"
VITE_VERIFY_SOULBOUND_CONTRACT_NAME="verify-soulbound"
VITE_REPUTATION_CONTRACT_NAME="rep-sft"
# These canonical SIP-010 token contract ids must match the on-chain allowlist configured via escrow-v2.set-supported-token-contract
VITE_SBTC_CONTRACT_ADDRESS="SM3VDXK3WZZSA84XXFKAFAF15NNZX32CTSG82JFQ4"
VITE_SBTC_CONTRACT_NAME="sbtc-token"
VITE_USDCX_CONTRACT_ADDRESS="SP120SBRBQJ00MCWS7TM5R8WJNTTKD5K0HFRC2CNE"
VITE_USDCX_CONTRACT_NAME="usdcx"
VITE_HIRO_API_BASE_URL="https://api.hiro.so"
REFUND_ADMIN_PRINCIPAL="SP37JRPTQ0KFMB3HAFVCCAWDQWHKRJCGBW1W19TJH"
